{
  "name": "germany-deal-travel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "update-data": "tsx scripts/update-data.ts && tsx scripts/update-heat-status.ts",
    "update-heat-status": "tsx scripts/update-heat-status.ts",
    "automation-summary": "tsx scripts/write-automation-summary.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test tests/**/*.test.ts",
    "quality": "npm run test && npm run typecheck",
    "check": "npm run quality && npm run update-data && npm run build"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "cheerio": "^1.1.2",
    "fast-xml-parser": "^5.3.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
